    "test:wav-bless": "tsx scripts/wav-bless.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "node-web-audio-api": "^2.0.0",
    "sass": "^1.100.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^3.2.4"
  }
}
