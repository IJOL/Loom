{
  "name": "tb303-synth",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fast": "vitest run --exclude 'src/**/*.dsp.test.ts'",
    "test:dsp": "vitest run .dsp.test.ts",
